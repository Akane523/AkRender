# ── AkRenderConfig.cmake ─────────────────────────────────────────────────────
# Package configuration for find_package(AkRender).
#
# Provides targets:
#   AkRender::AkRender            - Main renderer library (Vulkan + Slang + deps)
#
# ShaderSet is a separate package — use find_package(AkRenderShaderSet) for
# add_shader_set() and the ShaderSet runtime libraries.
#
# Usage:
#   find_package(AkRender REQUIRED)
#   target_link_libraries(my_app PRIVATE AkRender::AkRender)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Re-find transitive dependencies
# Note: consumer should include these in their own vcpkg.json
find_dependency(Vulkan)
find_dependency(VulkanMemoryAllocator)
find_dependency(glfw3)
find_dependency(glm)
find_dependency(spdlog)
find_dependency(Stb)

# Slang provides its own CMake config
find_dependency(slang CONFIG)

# Re-export the library target
if(NOT TARGET AkRender::AkRender)
    include("${CMAKE_CURRENT_LIST_DIR}/AkRenderTargets.cmake")
endif()

check_required_components(AkRender)
